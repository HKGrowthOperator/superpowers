# ─── Postgres (Daten-Backbone) ──────────────────────────────────────────────
POSTGRES_USER=cockpit
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=cockpit

# ─── Adressen (Domains) ─────────────────────────────────────────────────────
# Subdomains deiner bestehenden Domain, die auf den Server zeigen.
# Die App (Dashboard), die du im Browser öffnest:
APP_DOMAIN=cockpit.deinefirma.de
# Die Werkstatt (n8n), wo du Automationen baust:
N8N_DOMAIN=automationen.deinefirma.de
# Deine E-Mail (für das automatische https-Zertifikat von Let's Encrypt):
ACME_EMAIL=info@deinefirma.de

# ─── n8n (Automations-Runtime) ──────────────────────────────────────────────
# Login für die n8n-Oberfläche
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
# Schlüssel zum Verschlüsseln gespeicherter Credentials. EINMAL setzen, NIE ändern.
# Erzeugen mit:  openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32

# ─── KI-Anbieter (von den Automationen genutzt) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Web (die "magische Wand") ──────────────────────────────────────────────
# Im Container wird DATABASE_URL automatisch aus den POSTGRES_*-Werten gebaut.
# Nur für lokale Entwicklung (cd web && npm run dev) hier setzen:
# DATABASE_URL=postgres://cockpit:change-me-strong-password@localhost:5432/cockpit
# Geheimer Schlüssel zum Signieren der Login-Sitzungen. EINMAL setzen.
#   Erzeugen mit:  openssl rand -hex 32
AUTH_SECRET=replace-with-openssl-rand-hex-32

# ─── Allgemein ──────────────────────────────────────────────────────────────
TZ=Europe/Berlin
