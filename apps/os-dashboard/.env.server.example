# ─────────────────────────────────────────────────────────────────────────────
# Server-Konfiguration (CasaOS + Tailscale).
# Kopiere diese Datei nach ".env" und fülle ALLE Werte aus.
# Es gibt KEINE geheimen Werte "von außen" — alles legst DU hier fest.
# Geheimnisse erzeugen:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# 1) Datenbank (Passwort frei wählbar, stark)
POSTGRES_USER=cockpit
POSTGRES_PASSWORD=BITTE_STARKES_PASSWORT_SETZEN
POSTGRES_DB=cockpit

# 2) Session-Signatur der App  (openssl rand -hex 32)
AUTH_SECRET=BITTE_32_BYTE_HEX_SETZEN

# 3) n8n-Verschlüsselung        (openssl rand -hex 32)
N8N_ENCRYPTION_KEY=BITTE_32_BYTE_HEX_SETZEN

# 4) KI-Assistent (dein Anthropic-Schlüssel)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# 5) Google Drive (aus deiner Google-Cloud-App, Typ "Webanwendung")
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
# Muss EXAKT deiner öffentlichen Tailscale-URL + /api/google/callback sein:
GOOGLE_REDIRECT_URI=https://DEIN-RECHNER.DEIN-TAILNET.ts.net/api/google/callback
