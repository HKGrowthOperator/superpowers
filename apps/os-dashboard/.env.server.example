# ─────────────────────────────────────────────────────────────────────────────
# Server-Konfiguration. Kopiere nach ".env" und fülle die Werte aus.
# Es gibt KEINE Secrets "von außen" — alles legt ihr selbst fest.
# Geheimnisse erzeugen:  openssl rand -hex 32
# NUR diese Beispiel-Datei wird committet, niemals die echte .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── PFLICHT ──────────────────────────────────────────────────────────────────
# Datenbank
POSTGRES_USER=cockpit
POSTGRES_PASSWORD=BITTE_STARKES_PASSWORT_SETZEN
POSTGRES_DB=cockpit

# Session-Signatur der App   (openssl rand -hex 32)
AUTH_SECRET=BITTE_32_BYTE_HEX_SETZEN

# n8n-Verschlüsselung        (openssl rand -hex 32)
N8N_ENCRYPTION_KEY=BITTE_32_BYTE_HEX_SETZEN

# ── HOST-PORTS (optional, Defaults in Klammern) ──────────────────────────────
WEB_PORT=4000        # Host-Port der Web-App  (Default 3000)
N8N_PORT=5679        # Host-Port von n8n, nur 127.0.0.1  (Default 5678)

# ── KI-ASSISTENT (OPTIONAL) ──────────────────────────────────────────────────
# Ohne Schlüssel läuft das Dashboard normal; nur Chat-Assistent + Drive-Import
# sind dann deaktiviert.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── GOOGLE DRIVE (OPTIONAL) ──────────────────────────────────────────────────
# Leer lassen = /drive zeigt "nicht eingerichtet", Rest der App unberührt.
# Wenn genutzt: Client-Typ "Webanwendung", Redirect-URI exakt wie unten.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://hkgrowth.tail0398a8.ts.net:8443/api/google/callback
